---
import { getAssetURL } from "@utils/getImage";
import { getGlobal } from "@lib/cms";

const [siteGlobal, footerGlobal] = await Promise.all([
  getGlobal("site"),
  getGlobal("footer"),
]);
const site = siteGlobal?.data ?? {};
const footer = footerGlobal?.data ?? {};
let { pageUrl } = Astro.props;
const isCold = ["cold-storage-containers", "thank-you-coolers"].includes(pageUrl);
---

<footer class="bg-[#f7f7f7] text-dark py-12 lg:py-16">
  <div class="custom-container mx-auto flex flex-wrap justify-between">
    <!-- Logo -->
    <div class="w-full flex justify-center mb-6">
      {
        !isCold ? (
          <img
            src={getAssetURL(site.logo?.id ?? site.logo)}
            alt="Mi Box Logo"
            class="h-24 object-contain"
          />
        ) : (
          <img
            src={getAssetURL(site.ice_logo?.id ?? site.ice_logo ?? site.logo?.id ?? site.logo)}
            alt="Logo"
            class="h-24 object-contain"
          />
        )
      }
    </div>

    {
      !isCold && (
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 w-full my-14 items-start gap-8">
          {
            (footer.footer_sections ?? []).map((section: any) => (
              <div class="w-full mb-6">
                <h3 class="text-lg font-semibold">{section?.title}</h3>
                <ul class="mt-2 space-y-2">
                  {(section?.links ?? []).map((link: any) => (
                    <li>
                      <a href={link?.link} class="text-dark hover:text-primary">
                        {link?.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>

        <div class="flex justify-center md:flex-row flex-col w-full gap-4">
          {
            (footer.legal_links ?? []).map((item: any) => (
              <a href={item?.link} class="text-dark text-xs hover:text-primary">
                {item?.title}
              </a>
            ))
          }
        </div>
      )
    }

    <!-- Cold Storage Contact Info -->
    {
      isCold && (
        <div class="w-full text-center text-sm mt-4 text-dark space-y-1">
          <p>6510 3rd Ave W, Bradenton, FL 34209</p>
          <p>
            <a href="tel:19417777269" class="hover:text-primary">
              941-777-7269
            </a>
          </p>
        </div>
      )
    }

    <!-- Copyright -->
    <div class="w-full text-center text-sm mt-6 text-dark">
      {
        isCold ? (
          <p>2026 Box Rental Now, LLC / It's Ice Cold Storage. All Rights Reserved</p>
        ) : (
          <p set:html={footer?.copyright_description} />
        )
      }
    </div>
  </div>
</footer>
