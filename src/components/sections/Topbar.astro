---
import Tag from "@assets/tag.png";
import { getGlobal } from "@lib/cms";
const topbarGlobal = await getGlobal("topbar");
const title = topbarGlobal?.data?.title;
---

{
  title && (
    <div class="bg-yellow-300 py-3">
      <div class="flex items-center custom-container text-black font-bold py-2">
        <img src={Tag.src} class="mr-3 h-5" alt="Tag Icon" /> {title}
      </div>
    </div>
  )
}
