---
import { getGlobal } from "src/lib/getPageData";
import { getAssetURL } from "@utils/getImage";
import {
  movingCompanySchema,
  organizationSchema,
  websiteSchema,
} from "src/lib/schema";
import "../../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: any;
  schema?: object[];
}
const global = await getGlobal();
const { title, description, ogImage, schema = [] } = Astro.props;
const faviconId =
  typeof global?.favicon === "string" ? global.favicon : global?.favicon?.id;
const faviconUrl = getAssetURL(faviconId) || "/favicon.png";
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png+xml" href={faviconUrl} />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />

<!-- Google Tag Manager -->
<script is:inline>
  (function (w, d, s, l, i) {
    w[l] = w[l] || [];
    w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
    var f = d.getElementsByTagName(s)[0],
      j = d.createElement(s),
      dl = l != "dataLayer" ? "&l=" + l : "";
    j.async = true;
    j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
    f.parentNode.insertBefore(j, f);
  })(window, document, "script", "dataLayer", "GTM-P59R98JX");
</script>
<!-- End Google Tag Manager -->

<!-- Google tag (gtag.js) -->
<script
  is:inline
  async
  src="https://www.googletagmanager.com/gtag/js?id=AW-1056418154"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("js", new Date());

  gtag("config", "AW-1056418154");
</script>

<script is:inline>
  gtag("config", "AW-1056418154/_nnoCKCP7dwDEOrS3vcD", {
    phone_conversion_number: "(941) 777-7269",
  });
</script>

<!-- Sitewide schema (MovingCompany, Organization, WebSite) -->
{
  [movingCompanySchema, organizationSchema, websiteSchema].map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))
}

<!-- Page-specific schema injected per page -->
{
  schema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))
}
