---
import Layout from "@layouts/Layout.astro";
import BlockRenderer from "../blocks/BlockRenderer.astro";
import { getPage, listPageSlugs, preloadAssetsFromBlocks } from "@lib/cms";
import { buildSeoProps } from "@lib/seo";
import { serviceSchemaMap, buildBreadcrumbSchema } from "@lib/schema";

export const prerender = true;

export async function getStaticPaths() {
  const pages = await listPageSlugs();
  return pages
    .filter((p) => p.slug !== "home" && p.slug !== "index")
    .map((p) => ({ params: { slug: p.slug.replace(/^\//, "") } }));
}

const { slug } = Astro.params;
const safeSlug = typeof slug === "string" ? slug : "";
const pageData = await getPage(safeSlug);

if (pageData == null) {
  return Astro.redirect("/404");
}

await preloadAssetsFromBlocks(pageData.blocks);
const seo = await buildSeoProps(pageData, { title: pageData.title });

const serviceSchema = serviceSchemaMap[safeSlug];
const breadcrumbSchema = buildBreadcrumbSchema(safeSlug);
const pageSchema = [
  ...(serviceSchema ? [serviceSchema] : []),
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
];
---

<Layout
  title={seo.title}
  description={seo.description}
  ogImage={seo.ogImage ?? ""}
  pageUrl={slug}
  schema={pageSchema}
>
  <BlockRenderer blocks={pageData.blocks ?? []} />
</Layout>
