---
import Layout from "@layouts/Layout.astro";
import { formatDate } from "@utils/dateformatter";
import { getAssetURL } from "@utils/getImage";
import { getEntry, listEntries } from "@lib/cms";

export const prerender = true;

export async function getStaticPaths() {
  const entries = await listEntries("blogs");
  return entries.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const safeSlug = typeof slug === "string" ? slug : "";
const post = await getEntry("blogs", safeSlug);

if (!post) {
  return Astro.redirect("/404");
}

const fm = post.frontmatter ?? {};
const heroImage = getAssetURL(fm.blog_image?.id ?? fm.blog_image) ?? "";
const heroAlt = (typeof fm.blog_image === "object"
  ? fm.blog_image?.description ?? fm.blog_image?.title
  : null) ?? "Blog Hero Image";
---

<Layout
  title={fm.seo_title || post.title}
  description={fm.seo_description || fm.excerpt || ""}
  ogImage={getAssetURL(fm.og_image?.id ?? fm.og_image) ?? ""}
  pageUrl={`/blog/${slug}`}
>
  <div class="relative flex items-end text-white overflow-hidden" role="banner">
    <img
      src={heroImage}
      alt={heroAlt}
      class="absolute inset-0 w-full h-full object-cover -z-10 brightness-[0.55]"
    />
    <div class="custom-container w-full py-24">
      <div class="max-w-3xl">
        <p class="text-sm text-primary/90 uppercase tracking-wide mb-2">Blog</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-tight">
          {post.title}
        </h1>
        <div class="mt-4 flex items-center gap-4 text-gray-200">
          <time datetime={fm.publication_date} class="text-sm">
            {fm.publication_date ? formatDate(fm.publication_date) : ""}
          </time>
        </div>
      </div>
    </div>
  </div>
  <div class="custom-container py-16">
    <div
      class="prose prose-headings:text-primary !max-w-5xl mx-auto prose-headings:font-semibold prose-a:text-primary pt-8 md:pb-12 pb-6"
    >
      <div set:html={post.body} />
    </div>
  </div>
</Layout>
