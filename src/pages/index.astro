---
export const prerender = false;

import Layout from "@layouts/Layout.astro";
import BlockRenderer from "../blocks/BlockRenderer.astro";
import { getPage, preloadAssetsFromBlocks } from "@lib/cms";
import { buildSeoProps } from "@lib/seo";
import { containerProductSchemas, buildFaqSchema } from "@lib/schema";

const pageData = await getPage("home");

if (pageData == null) {
  return Astro.redirect("/404");
}

await preloadAssetsFromBlocks(pageData.blocks);

const seo = await buildSeoProps(pageData);

const faqBlock = pageData.blocks.find((b) => b.type === "faqs");
const faqList = faqBlock?.data?.list ?? [];
const faqSchema = buildFaqSchema(faqList);

const homepageSchema = [
  ...containerProductSchemas,
  ...(faqSchema ? [faqSchema] : []),
];
---

<Layout
  title={seo.title}
  description={seo.description ?? ""}
  ogImage={seo.ogImage ?? ""}
  schema={homepageSchema}
>
  <BlockRenderer blocks={pageData.blocks ?? []} />
</Layout>
